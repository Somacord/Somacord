# Copy this file to .env.local and fill in real values for local development.
# Never commit .env.local — see .gitignore.
#
# Variable names below match /somacord-docs/docs/engineering/development-guidelines.md
# exactly — that doc is the source of truth if these ever drift.

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/_/settings/api
#
# Auth > Providers > Google must also be configured in the Supabase
# Dashboard (Client ID + Secret from Google Cloud Console) for "Sign in
# with Google" to work — see supabase/config.toml for the local-dev
# equivalent and required redirect URI.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses Row Level Security — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe — Somacord Membership billing (docs/business/pricing.md)
# $29/month is the single plan offered at launch. The quarterly/yearly price
# IDs below are reserved for a possible future annual plan, not currently
# offered. Not used yet — Stripe checkout is a later milestone.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MEMBERSHIP_MONTHLY_PRICE_ID=
STRIPE_MEMBERSHIP_QUARTERLY_PRICE_ID=
STRIPE_MEMBERSHIP_YEARLY_PRICE_ID=

# ---------------------------------------------------------------------------
# Resend — transactional email. Used today for the Community Partner inquiry
# form (src/lib/actions/partner-inquiries.ts) — signup/notification email is
# reserved for a later pass.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Somacord <hello@somacord.com>"
